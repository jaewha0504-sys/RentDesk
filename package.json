{
  "name": "rentdesk",
  "version": "1.0.0",
  "description": "RentDesk - 건물 임대관리",
  "main": "main.js",
  "author": "RentDesk",
  "license": "UNLICENSED",
  "repository": "github:jaewha0504-sys/RentDesk",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.rentdesk.app",
    "productName": "RentDesk",
    "publish": { "provider": "github", "owner": "jaewha0504-sys", "repo": "RentDesk" },
    "files": ["main.js", "preload.js", "renderer/**/*", "icon/**/*"],
    "directories": { "buildResources": "build", "output": "dist" },
    "mac": { "category": "public.app-category.business", "target": "dmg", "identity": null, "icon": "build/icon.png" },
    "win": { "target": "nsis", "icon": "build/icon.png" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "shortcutName": "RentDesk" }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
